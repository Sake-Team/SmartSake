# SmartSake AP-mode config — sourced by scripts/ap-mode.sh.
# Edit these to change the access-point name, password, or network range.
# After editing, run: sudo ./restart.sh --ap

# WiFi SSID broadcast by the Pi
AP_SSID="SmartSake"

# WPA2 password (8-63 chars). Default is intentionally simple for in-room use;
# change it if the brewing space is publicly accessible.
AP_PASS="kojitable"

# 2.4 GHz channel (1, 6, or 11 are the non-overlapping classics)
AP_CHANNEL=6

# Static IP for the Pi while in AP mode
AP_GATEWAY="192.168.50.1"
AP_NETMASK="255.255.255.0"
AP_CIDR="24"

# DHCP pool for clients (must be in the same /24 as AP_GATEWAY)
AP_DHCP_START="192.168.50.50"
AP_DHCP_END="192.168.50.150"
AP_DHCP_LEASE="24h"

# Wireless interface (almost always wlan0 on a Pi 4B)
AP_IFACE="wlan0"
